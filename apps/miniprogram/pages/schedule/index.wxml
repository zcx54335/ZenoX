<view class="page">
  <view class="section">
    <text class="eyebrow">Week</text>
    <text class="title">本周课程</text>
  </view>

  <block wx:for="{{week}}" wx:key="name">
    <view class="courseCard">
      <text class="pill">{{item.day}} {{item.time}}</text>
      <text class="courseName">{{item.name}}</text>
      <text class="muted">{{item.room}}</text>
    </view>
  </block>
</view>
