.profile {
  display: grid;
  justify-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 44rpx 28rpx;
  border-radius: 16rpx;
  background: #101719;
  color: #ffffff;
}

.profile .muted {
  color: #b7c8c8;
}

.avatar {
  display: grid;
  place-items: center;
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: #def8ef;
  color: #0b7663;
  font-size: 48rpx;
  font-weight: 900;
}

.walletRow {
  display: flex;
  justify-content: space-between;
  padding: 26rpx 0;
  border-bottom: 1rpx solid #e7eceb;
  font-weight: 800;
}

.walletRow:last-child {
  border-bottom: 0;
}
