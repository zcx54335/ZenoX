.hero {
  min-height: 300rpx;
  padding: 34rpx;
  border-radius: 16rpx;
  background: #101719;
  color: #ffffff;
}

.hero .muted {
  display: block;
  margin-top: 18rpx;
  color: #b7c8c8;
}

.quickGrid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: 24rpx 0;
}

.quickCard {
  padding: 26rpx;
  border-radius: 16rpx;
  background: #ffffff;
}

.quickNumber {
  display: block;
  margin-top: 12rpx;
  font-size: 44rpx;
  font-weight: 900;
}

.lessonRow {
  display: flex;
  gap: 22rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #e7eceb;
}

.lessonRow:last-child {
  border-bottom: 0;
}

.lessonTime,
.lessonTitle {
  display: block;
  font-weight: 850;
}

.lessonTime {
  width: 150rpx;
}
